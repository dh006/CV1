PORT=5000

# === LOCAL (development) ===
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=clothing_store

# === PRODUCTION (Railway sẽ tự cung cấp DATABASE_URL) ===
# DATABASE_URL=mysql://user:pass@host:port/dbname

# JWT
JWT_SECRET=DIEP_COLLECTION_SECRET_KEY_2026_SUPER_SECURE

# Email Gmail App Password
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# CORS — điền domain Vercel sau khi deploy
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# SePay webhook (tùy chọn — để QR tự xác nhận)
# SEPAY_WEBHOOK_API_KEY=your_sepay_key
